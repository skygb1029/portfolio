# Google Analytics 4 Measurement ID (G-XXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Microsoft Clarity Project ID
VITE_CLARITY_PROJECT_ID=

# Google Form — 表單「傳送」網址（Supabase 未設定時的備援）
VITE_WAITLIST_FORM_ACTION=
VITE_WAITLIST_ENTRY_NAME=entry.123456789
VITE_WAITLIST_ENTRY_EMAIL=entry.987654321
VITE_WAITLIST_ENTRY_PRODUCT=entry.111222333

# Admin Dashboard — 與伺服器 ADMIN_API_SECRET 相同
VITE_ADMIN_API_SECRET=

# AI 股票秘書 Public API（建議，與 web-widget 一致）
VITE_API_BASE=http://localhost:3002/api/web
# 舊版：僅 host，會自動補 /api/web
# VITE_STOCK_API_URL=http://localhost:3002
# 正式：VITE_API_BASE=https://stock-api.jrjim.ai/api/web

# --- Vercel 伺服器環境變數（勿加 VITE_ 前綴）---
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# ADMIN_API_SECRET=
# GITHUB_TOKEN=（選用，提高 API 限額）
# GITHUB_OWNER=skygb1029
